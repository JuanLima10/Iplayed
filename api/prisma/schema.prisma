generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum progress_status {
  TO_PLAY
  PLAYING
  COMPLETED
  ABANDONED
}

model user {
  id          String    @id @default(uuid())
  provider    String
  provider_id String
  username    String?
  name        String?
  email       String?
  avatar_url  String?
  created_at  DateTime  @default(now())
  updated_at  DateTime? @updatedAt
  active      Boolean

  game_statuses game_status[]
  lists         game_list[]
  reviews       review[]
  sync_metadata sync_metadata[]

  @@unique([provider, provider_id])
  @@index([username])
}

model game {
  id         String    @id @default(uuid())
  igdb_id    Int?      @unique
  title      String
  slug       String?
  cover_id   String?
  created_at DateTime  @default(now())
  updated_at DateTime? @updatedAt

  statuses   game_status[]
  reviews    review[]
  list_items list_item[]

  @@index([title])
}

model game_status {
  id             String          @id @default(uuid())
  user           user            @relation(fields: [user_id], references: [id], onDelete: Cascade)
  user_id        String
  game           game            @relation(fields: [game_id], references: [id], onDelete: Cascade)
  game_id        String
  status         progress_status
  progress       Int?
  best           Int?
  is_favorite    Boolean         @default(false)
  rating         Float?
  last_played_at DateTime?
  created_at     DateTime        @default(now())
  updated_at     DateTime?       @updatedAt

  @@unique([user_id, game_id])
  @@index([user_id])
  @@index([game_id])
}

model review {
  id         String    @id @default(uuid())
  user       user      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  user_id    String
  game       game      @relation(fields: [game_id], references: [id], onDelete: Cascade)
  game_id    String
  text       String
  created_at DateTime  @default(now())
  updated_at DateTime? @updatedAt

  @@unique([user_id, game_id])
  @@index([user_id])
  @@index([game_id])
}

model game_list {
  id         String      @id @default(uuid())
  user       user        @relation(fields: [user_id], references: [id], onDelete: Cascade)
  user_id    String
  name       String
  created_at DateTime    @default(now())
  updated_at DateTime?   @updatedAt
  items      list_item[]

  @@unique([user_id, name])
  @@index([user_id, name])
}

model list_item {
  id       String    @id @default(uuid())
  list     game_list @relation(fields: [list_id], references: [id], onDelete: Cascade)
  list_id  String
  game     game      @relation(fields: [game_id], references: [id], onDelete: Cascade)
  game_id  String
  position Int       @default(0)
  added_at DateTime  @default(now())

  @@unique([list_id, game_id])
  @@index([list_id])
  @@index([game_id])
}

model sync_metadata {
  id        String   @id @default(uuid())
  user      user     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  user_id   String
  last_sync DateTime
  device_id String?

  @@unique([user_id, device_id])
}
